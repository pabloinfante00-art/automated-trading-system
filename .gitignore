# Raw SimFin bulk downloads — too large for GitHub, download manually
data/*.csv

# Processed CSVs and trained models ARE committed intentionally:
# Streamlit Cloud has no local data, so these pre-built artifacts are
# required for the app to run without re-running the full ETL + training.
# data/processed/*.csv  ← committed
# models/*.pkl          ← committed

# API keys and secrets — NEVER commit these!
.env
app/.streamlit/secrets.toml

